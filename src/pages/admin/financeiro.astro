---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { financeSummary, transactions } from '../../legacy/mocks/finance';

const income = transactions.filter((item) => item.type === 'entrada').reduce((total, item) => total + item.amount, 0);
const expense = Math.abs(transactions.filter((item) => item.type === 'saida').reduce((total, item) => total + item.amount, 0));
const categories = [...new Set(transactions.map((item) => item.category))].map((category) => {
  const total = transactions
    .filter((item) => item.category === category)
    .reduce((sum, item) => sum + Math.abs(item.amount), 0);

  return { category, total };
}).sort((left, right) => right.total - left.total);
const highestCategory = categories[0]?.total ?? 1;
const cashflowSeries = [
  { label: 'Sem 1', income: 3200, expense: 1100 },
  { label: 'Sem 2', income: 4100, expense: 1500 },
  { label: 'Sem 3', income: 3650, expense: 1380 },
  { label: 'Sem 4', income, expense },
];
const maxCashflow = Math.max(...cashflowSeries.flatMap((item) => [item.income, item.expense]));
const netMargin = Math.round((financeSummary.balance / financeSummary.income) * 100);
const totalTransactions = income + expense;
const incomeShare = Math.round((income / totalTransactions) * 100);
const expenseShare = 100 - incomeShare;
const financeCircumference = 2 * Math.PI * 54;
const incomeStroke = (incomeShare / 100) * financeCircumference;

const formatCurrency = (amount: number) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(amount);
---

<AdminLayout title="Gestão financeira | IBR Canaã" heading="Gestão financeira" subheading="Dízimos, ofertas, despesas, saldo mensal e prestação de contas para diretoria.">
  <section class="rounded-[1.75rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-canaa-950 to-canaa-800 p-6 text-white shadow-sm">
    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr] xl:items-end">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.24em] text-gold-300">Painel executivo</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight">Fluxo financeiro com foco em previsibilidade e prestação de contas</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-200">Leitura consolidada de entradas, saídas e categorias que mais pressionam o caixa no período atual.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-200">Saldo atual</p>
          <p class="mt-2 text-3xl font-black text-white">{formatCurrency(financeSummary.balance)}</p>
        </div>
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-200">Margem líquida</p>
          <p class="mt-2 text-3xl font-black text-gold-300">{netMargin}%</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-6 grid gap-4 md:grid-cols-3">
    {[
      { label: 'Saldo atual', value: formatCurrency(financeSummary.balance), detail: `+${financeSummary.trend.value}% no período`, tone: 'text-canaa-800' },
      { label: 'Entradas', value: formatCurrency(income), detail: `${incomeShare}% do fluxo financeiro`, tone: 'text-emerald-600' },
      { label: 'Saídas', value: formatCurrency(expense), detail: `${expenseShare}% do fluxo financeiro`, tone: 'text-rose-600' },
    ].map((card) => (
      <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-100/80">
        <p class="text-sm font-bold text-slate-500">{card.label}</p>
        <p class:list={["mt-3 text-3xl font-black tracking-tight", card.tone]}>{card.value}</p>
        <p class="mt-2 text-sm font-semibold text-slate-500">{card.detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-6 grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-100/80">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Fluxo semanal</p>
          <h2 class="mt-2 text-2xl font-black">Comparativo de entradas e saídas</h2>
        </div>
        <span class="rounded-full bg-emerald-50 px-4 py-2 text-sm font-black text-emerald-700">Superávit {formatCurrency(financeSummary.balance)}</span>
      </div>
      <div class="mt-8 rounded-[2rem] border border-slate-100 bg-gradient-to-br from-slate-50 to-canaa-50 p-5">
        <div class="grid grid-cols-4 gap-4">
          {cashflowSeries.map((item) => (
            <div class="space-y-3 text-center">
              <div class="flex h-56 items-end justify-center gap-3 rounded-[1.5rem] bg-white px-3 py-4 ring-1 ring-slate-100">
                <div class="flex h-full w-10 items-end rounded-full bg-emerald-50">
                  <div class="w-full rounded-full bg-emerald-500" style={`height: ${(item.income / maxCashflow) * 100}%`}></div>
                </div>
                <div class="flex h-full w-10 items-end rounded-full bg-rose-50">
                  <div class="w-full rounded-full bg-rose-500" style={`height: ${(item.expense / maxCashflow) * 100}%`}></div>
                </div>
              </div>
              <div>
                <p class="text-xs font-black uppercase tracking-[0.16em] text-slate-400">{item.label}</p>
                <p class="mt-1 text-xs font-bold text-emerald-600">{formatCurrency(item.income)}</p>
                <p class="text-xs font-bold text-rose-600">{formatCurrency(item.expense)}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </article>

    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-black">Composição do caixa</h2>
      <div class="mt-6 grid gap-6 lg:grid-cols-[160px_minmax(0,1fr)] lg:items-center">
        <div class="mx-auto">
          <svg viewBox="0 0 140 140" class="h-36 w-36" aria-label="Distribuição entre entradas e saídas">
            <circle cx="70" cy="70" r="54" fill="none" stroke="#e2e8f0" stroke-width="16" />
            <circle cx="70" cy="70" r="54" fill="none" stroke="#10b981" stroke-width="16" stroke-linecap="round" stroke-dasharray={`${incomeStroke} ${financeCircumference}`} transform="rotate(-90 70 70)" />
            <circle cx="70" cy="70" r="54" fill="none" stroke="#f43f5e" stroke-width="16" stroke-linecap="round" stroke-dasharray={`${financeCircumference - incomeStroke} ${financeCircumference}`} stroke-dashoffset={-incomeStroke} transform="rotate(-90 70 70)" />
            <text x="70" y="62" text-anchor="middle" fill="#64748b" font-size="12" font-weight="800">Saldo</text>
            <text x="70" y="82" text-anchor="middle" fill="#0f172a" font-size="16" font-weight="900">{formatCurrency(financeSummary.balance)}</text>
          </svg>
        </div>
        <div class="space-y-5">
          <div>
            <div class="flex justify-between text-sm font-black"><span>Entradas</span><span>{formatCurrency(income)}</span></div>
            <div class="mt-2 h-3 overflow-hidden rounded-full bg-slate-100"><div class="h-full rounded-full bg-emerald-500" style={`width: ${incomeShare}%`}></div></div>
             <p class="mt-2 text-xs font-bold uppercase tracking-[0.14em] text-slate-400">{incomeShare}% do fluxo do período</p>
          </div>
          <div>
             <div class="flex justify-between text-sm font-black"><span>Saídas</span><span>{formatCurrency(expense)}</span></div>
            <div class="mt-2 h-3 overflow-hidden rounded-full bg-slate-100"><div class="h-full rounded-full bg-rose-500" style={`width: ${expenseShare}%`}></div></div>
             <p class="mt-2 text-xs font-bold uppercase tracking-[0.14em] text-slate-400">{expenseShare}% do fluxo do período</p>
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="mt-6 grid gap-6 xl:grid-cols-[0.85fr_1.15fr]">
    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Categorias</p>
      <h2 class="mt-2 text-2xl font-black">Pressão por centro de custo</h2>
      <div class="mt-6 space-y-4">
        {categories.map((item) => (
          <div class="rounded-3xl bg-slate-50 p-5 ring-1 ring-slate-100">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="font-black text-slate-950">{item.category}</p>
                <p class="mt-1 text-sm font-semibold text-slate-500">{formatCurrency(item.total)} movimentados</p>
              </div>
              <span class="text-lg font-black text-canaa-800">{Math.round((item.total / highestCategory) * 100)}%</span>
            </div>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-white ring-1 ring-slate-100">
              <div class="h-full rounded-full bg-gradient-to-r from-canaa-950 via-canaa-800 to-gold-500" style={`width: ${(item.total / highestCategory) * 100}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
      <div class="flex flex-col gap-4 border-b border-slate-200 p-5 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Lançamentos</p>
          <h2 class="mt-2 text-2xl font-black">Movimentações recentes</h2>
        </div>
         <button class="rounded-full bg-canaa-800 px-4 py-2 text-sm font-black text-white" type="button">Novo lançamento</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[720px] text-left">
          <thead class="bg-slate-50 text-sm font-bold text-slate-500">
            <tr>
              <th class="px-5 py-4">Data</th>
               <th class="px-5 py-4">Descrição</th>
              <th class="px-5 py-4">Categoria</th>
              <th class="px-5 py-4 text-right">Valor</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {transactions.map((item) => (
              <tr>
                <td class="px-5 py-4 text-sm text-slate-500">{new Date(item.date).toLocaleDateString('pt-BR')}</td>
                <td class="px-5 py-4 font-bold text-slate-950">{item.description}</td>
                <td class="px-5 py-4 text-slate-600">{item.category}</td>
                <td class:list={["px-5 py-4 text-right font-black", item.amount > 0 ? 'text-emerald-600' : 'text-rose-600']}>
                  {formatCurrency(item.amount)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>
  </section>
</AdminLayout>
