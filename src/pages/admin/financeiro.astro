---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { financeSummary, transactions } from '../../legacy/mocks/finance';

const income = transactions.filter((item) => item.type === 'entrada').reduce((total, item) => total + item.amount, 0);
const expense = Math.abs(transactions.filter((item) => item.type === 'saida').reduce((total, item) => total + item.amount, 0));
const formatCurrency = (amount: number) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(amount);
---

<AdminLayout title="Gestao financeira | IBR Canaa" heading="Gestao financeira" subheading="Dizimos, ofertas, despesas, saldo mensal e prestacao de contas para diretoria.">
  <section class="grid gap-4 md:grid-cols-3"><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Saldo atual</p><p class="mt-3 text-3xl font-black text-canaa-800">{formatCurrency(financeSummary.balance)}</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Entradas</p><p class="mt-3 text-3xl font-black text-emerald-600">{formatCurrency(income)}</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Saidas</p><p class="mt-3 text-3xl font-black text-rose-600">{formatCurrency(expense)}</p></article></section>
  <section class="mt-6 grid gap-6 xl:grid-cols-[0.8fr_1.2fr]"><article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-2xl font-black">Resumo mensal</h2><div class="mt-6 space-y-5"><div><div class="flex justify-between text-sm font-black"><span>Dizimos e ofertas</span><span>{formatCurrency(income)}</span></div><div class="mt-2 h-3 rounded-full bg-slate-100"><div class="h-full rounded-full bg-emerald-500" style="width: 80%"></div></div></div><div><div class="flex justify-between text-sm font-black"><span>Despesas</span><span>{formatCurrency(expense)}</span></div><div class="mt-2 h-3 rounded-full bg-slate-100"><div class="h-full rounded-full bg-rose-500" style="width: 38%"></div></div></div></div></article><article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm"><div class="flex items-center justify-between border-b border-slate-200 p-5"><h2 class="text-2xl font-black">Lancamentos</h2><button class="rounded-full bg-canaa-800 px-4 py-2 text-sm font-black text-white" type="button">Novo lancamento</button></div><div class="overflow-x-auto"><table class="w-full min-w-[720px] text-left"><thead class="bg-slate-50 text-sm font-bold text-slate-500"><tr><th class="px-5 py-4">Data</th><th class="px-5 py-4">Descricao</th><th class="px-5 py-4">Categoria</th><th class="px-5 py-4 text-right">Valor</th></tr></thead><tbody class="divide-y divide-slate-100">{transactions.map((item) => (<tr><td class="px-5 py-4 text-sm text-slate-500">{new Date(item.date).toLocaleDateString('pt-BR')}</td><td class="px-5 py-4 font-bold text-slate-950">{item.description}</td><td class="px-5 py-4 text-slate-600">{item.category}</td><td class:list={["px-5 py-4 text-right font-black", item.amount > 0 ? 'text-emerald-600' : 'text-rose-600']}>{formatCurrency(item.amount)}</td></tr>))}</tbody></table></div></article></section>
</AdminLayout>
