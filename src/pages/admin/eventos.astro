---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { events } from '../../legacy/mocks/events';

const formatDate = (date: string) => new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(date));
---

<AdminLayout title="Eventos e agenda | IBR Canaa" heading="Eventos e agenda" subheading="Cultos, reunioes, conferencias, lembretes e controle de presenca por evento.">
  <section class="grid gap-4 md:grid-cols-3"><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Eventos ativos</p><p class="mt-3 text-3xl font-black text-canaa-800">{events.length}</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Presenca prevista</p><p class="mt-3 text-3xl font-black text-canaa-800">900</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Lembretes</p><p class="mt-3 text-3xl font-black text-canaa-800">4</p></article></section>
  <section class="mt-6 grid gap-6 xl:grid-cols-[1fr_360px]">
    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><div class="flex items-center justify-between gap-4"><h2 class="text-2xl font-black">Calendario operacional</h2><button class="rounded-full bg-canaa-800 px-4 py-2 text-sm font-black text-white" type="button">Criar evento</button></div><div class="mt-6 grid gap-4 md:grid-cols-2">{events.map((event) => (<div class="rounded-3xl border border-slate-100 bg-slate-50 p-5"><p class="font-black text-slate-950">{event.title}</p><p class="mt-2 text-sm font-semibold text-slate-500">{formatDate(event.date)} | {event.location}</p><div class="mt-4 flex items-center justify-between"><span class="rounded-full bg-white px-3 py-1 text-xs font-black text-canaa-800 ring-1 ring-slate-200">{event.type}</span><span class="text-sm font-black text-slate-600">{event.attendees} pessoas</span></div></div>))}</div></article>
    <aside class="space-y-6"><article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-black">Escala de voluntarios</h2><div class="mt-5 space-y-3 text-sm font-bold text-slate-600"><p class="rounded-2xl bg-slate-50 p-4">Recepcao: 3 confirmados</p><p class="rounded-2xl bg-slate-50 p-4">Louvor: escala pendente</p><p class="rounded-2xl bg-slate-50 p-4">Infantil: 2 vagas abertas</p></div></article><article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-black">Notificacoes</h2><p class="mt-4 text-sm leading-6 text-slate-600">Envie lembretes por WhatsApp ou e-mail para lideres e participantes confirmados.</p></article></aside>
  </section>
</AdminLayout>
