---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ministries } from '../../legacy/mocks/ministries';
---

<AdminLayout title="Relatorios e analises | IBR Canaa" heading="Relatorios e analises" subheading="Crescimento, frequencia, financeiro, engajamento ministerial e exportacoes.">
  <section class="grid gap-4 md:grid-cols-3"><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Crescimento mensal</p><p class="mt-3 text-3xl font-black text-emerald-600">+12%</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Engajamento</p><p class="mt-3 text-3xl font-black text-canaa-800">78%</p></article><article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm"><p class="text-sm font-bold text-slate-500">Exportacoes prontas</p><p class="mt-3 text-3xl font-black text-canaa-800">5</p></article></section>
  <section class="mt-6 grid gap-6 xl:grid-cols-[1fr_0.8fr]"><article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-2xl font-black">Crescimento e frequencia</h2><div class="mt-8 flex h-72 items-end gap-4 rounded-3xl bg-slate-50 p-5">{[45, 52, 58, 64, 70, 78].map((value) => (<div class="flex flex-1 items-end rounded-full bg-white p-1 ring-1 ring-slate-100"><div class="w-full rounded-full bg-gradient-to-t from-canaa-800 to-blue-400" style={`height: ${value}%`}></div></div>))}</div></article><article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-2xl font-black">Exportar dados</h2><div class="mt-6 grid gap-3"><button class="rounded-2xl bg-canaa-800 p-4 text-left font-black text-white" type="button">Relatorio financeiro PDF</button><button class="rounded-2xl border border-slate-200 p-4 text-left font-black text-slate-700" type="button">Membros em Excel</button><button class="rounded-2xl border border-slate-200 p-4 text-left font-black text-slate-700" type="button">Frequencia por evento</button></div></article></section>
  <section class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-2xl font-black">Engajamento por ministerio</h2><div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">{ministries.map((ministry) => (<article class="rounded-3xl bg-slate-50 p-5 ring-1 ring-slate-100"><div class="flex items-center justify-between"><p class="font-black text-slate-950">{ministry.name}</p><span class="text-sm font-black text-canaa-800">{ministry.members}</span></div><p class="mt-2 text-sm text-slate-500">Lider: {ministry.leader}</p><div class="mt-4 h-2 rounded-full bg-white"><div class="h-full rounded-full bg-canaa-800" style={`width: ${Math.min(ministry.members * 3, 100)}%`}></div></div></article>))}</div></section>
</AdminLayout>
