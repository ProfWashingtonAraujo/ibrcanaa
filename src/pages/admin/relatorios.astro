---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ministries } from '../../legacy/mocks/ministries';
import { members } from '../../legacy/mocks/members';
import { events } from '../../legacy/mocks/events';

const activeMembers = members.filter((member) => member.status === 'Ativo' || member.status === 'Liderança').length;
const averageFrequency = Math.round(members.reduce((total, member) => total + member.frequency, 0) / members.length);
const monthlyGrowth = 12;
const reportsReady = 5;
const attendanceSeries = [45, 52, 58, 64, 70, averageFrequency];
const attendanceLabels = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Atual'];
const maxAttendance = Math.max(...attendanceSeries);
const chartHeight = 220;
const chartWidth = 560;
const pointGap = chartWidth / (attendanceSeries.length - 1);
const toChartY = (value: number) => chartHeight - (value / maxAttendance) * (chartHeight - 24) - 12;
const attendancePoints = attendanceSeries.map((value, index) => `${index * pointGap},${toChartY(value)}`).join(' ');
const attendanceAreaPoints = `0,${chartHeight} ${attendancePoints} ${chartWidth},${chartHeight}`;
const maxMinistryMembers = Math.max(...ministries.map((ministry) => ministry.members));
const ministryHealth = ministries.map((ministry) => ({
  ...ministry,
  engagement: Math.min(ministry.members * 3, 100),
}));
const exportActions = [
  { title: 'Relatorio financeiro PDF', detail: 'Prestacao de contas executiva para diretoria', tone: 'primary' },
  { title: 'Membros em Excel', detail: 'Base completa para secretaria e acompanhamento', tone: 'secondary' },
  { title: 'Frequencia por evento', detail: 'Leitura de participacao por culto e reuniao', tone: 'secondary' },
];
---

<AdminLayout title="Relatorios e analises | IBR Canaa" heading="Relatorios e analises" subheading="Crescimento, frequencia, financeiro, engajamento ministerial e exportacoes.">
  <section class="rounded-[1.75rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-canaa-950 to-canaa-800 p-6 text-white shadow-sm">
    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr] xl:items-end">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.24em] text-gold-300">Inteligencia ministerial</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight">Relatorios prontos para leitura executiva e acao pastoral</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-200">Uma camada de sintese para acompanhar crescimento, frequencia e distribuicao de forca entre os ministerios.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-200">Membros ativos</p>
          <p class="mt-2 text-3xl font-black text-white">{activeMembers}</p>
        </div>
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-slate-200">Eventos monitorados</p>
          <p class="mt-2 text-3xl font-black text-gold-300">{events.length}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-6 grid gap-4 md:grid-cols-3">
    {[
      { label: 'Crescimento mensal', value: `+${monthlyGrowth}%`, detail: 'ritmo de expansao da base', tone: 'text-emerald-600' },
      { label: 'Engajamento', value: `${averageFrequency}%`, detail: 'presenca media da comunidade', tone: 'text-canaa-800' },
      { label: 'Exportacoes prontas', value: reportsReady, detail: 'arquivos disponiveis para envio', tone: 'text-canaa-800' },
    ].map((card) => (
      <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-100/80">
        <p class="text-sm font-bold text-slate-500">{card.label}</p>
        <p class:list={["mt-3 text-3xl font-black tracking-tight", card.tone]}>{card.value}</p>
        <p class="mt-2 text-sm font-semibold text-slate-500">{card.detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-6 grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-100/80">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Tendencia consolidada</p>
          <h2 class="mt-2 text-2xl font-black">Crescimento e frequencia</h2>
        </div>
        <span class="rounded-full bg-emerald-50 px-4 py-2 text-sm font-black text-emerald-700">Atual {averageFrequency}%</span>
      </div>
      <div class="mt-8 rounded-[2rem] border border-slate-100 bg-gradient-to-br from-slate-50 to-canaa-50 p-4 sm:p-6">
        <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="h-64 w-full overflow-visible" aria-label="Grafico de crescimento e frequencia">
          {[25, 50, 75, 100].map((mark) => {
            const y = toChartY(mark);
            return (
              <g>
                <line x1="0" y1={y} x2={chartWidth} y2={y} stroke="#cbd5e1" stroke-dasharray="6 8" stroke-width="1" />
                <text x="0" y={y - 6} fill="#64748b" font-size="12" font-weight="700">{mark}%</text>
              </g>
            );
          })}
          <polygon points={attendanceAreaPoints} fill="url(#attendanceGradient)" />
          <polyline points={attendancePoints} fill="none" stroke="#1e3a8a" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
          {attendanceSeries.map((value, index) => {
            const x = index * pointGap;
            const y = toChartY(value);
            return (
              <g>
                <circle cx={x} cy={y} r="6" fill="#ffffff" stroke="#1e3a8a" stroke-width="4" />
                <text x={x} y={y - 16} text-anchor="middle" fill="#0f172a" font-size="12" font-weight="800">{value}%</text>
              </g>
            );
          })}
          <defs>
            <linearGradient id="attendanceGradient" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#2563eb" stop-opacity="0.30" />
              <stop offset="100%" stop-color="#2563eb" stop-opacity="0.04" />
            </linearGradient>
          </defs>
        </svg>
        <div class="mt-4 grid grid-cols-3 gap-3 text-center text-xs font-black text-slate-500 sm:grid-cols-6">
          {attendanceLabels.map((label) => (
            <span>{label}</span>
          ))}
        </div>
      </div>
    </article>

    <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Exportacoes</p>
      <h2 class="mt-2 text-2xl font-black">Pacotes prontos</h2>
      <div class="mt-6 grid gap-3">
        {exportActions.map((action) => (
          <button
            class:list={[
              'rounded-2xl p-4 text-left transition',
              action.tone === 'primary' ? 'bg-canaa-800 text-white hover:bg-canaa-950' : 'border border-slate-200 text-slate-700 hover:bg-slate-50',
            ]}
            type="button"
          >
            <span class="block font-black">{action.title}</span>
            <span class:list={["mt-1 block text-sm", action.tone === 'primary' ? 'text-slate-200' : 'text-slate-500']}>
              {action.detail}
            </span>
          </button>
        ))}
      </div>
    </article>
  </section>

  <section class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.2em] text-canaa-800">Ministerios</p>
        <h2 class="mt-2 text-2xl font-black">Engajamento por frente de trabalho</h2>
      </div>
      <p class="text-sm font-semibold text-slate-500">Capacidade relativa por equipe e necessidade de reforco operacional.</p>
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {ministryHealth.map((ministry) => (
        <article class="rounded-3xl bg-slate-50 p-5 ring-1 ring-slate-100">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-black text-slate-950">{ministry.name}</p>
              <p class="mt-1 text-sm text-slate-500">Lider: {ministry.leader}</p>
            </div>
            <span class:list={[
              'rounded-full px-3 py-1 text-xs font-black',
              ministry.status === 'Precisa Voluntários' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700',
            ]}>
              {ministry.status}
            </span>
          </div>
          <div class="mt-5 flex items-end justify-between gap-4">
            <div>
              <p class="text-3xl font-black text-canaa-800">{ministry.members}</p>
              <p class="text-sm font-semibold text-slate-500">voluntarios ativos</p>
            </div>
            <p class="text-sm font-black text-slate-400">{Math.round((ministry.members / maxMinistryMembers) * 100)}% da maior equipe</p>
          </div>
          <div class="mt-4 h-3 overflow-hidden rounded-full bg-white ring-1 ring-slate-100">
            <div class="h-full rounded-full bg-gradient-to-r from-canaa-950 via-canaa-800 to-gold-500" style={`width: ${ministry.engagement}%`}></div>
          </div>
        </article>
      ))}
    </div>
  </section>
</AdminLayout>
