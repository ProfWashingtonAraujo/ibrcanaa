---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Obrigado pelo contato | Igreja Batista Regular Canaa" description="Recebemos seu interesse. A equipe da Igreja Batista Regular Canaa entrara em contato em breve.">
  <main class="min-h-screen bg-[radial-gradient(circle_at_top,rgba(248,217,139,0.2),transparent_30%),linear-gradient(135deg,#07152f,#0f172a)] px-5 py-20 text-white">
    <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center text-center">
      <p class="rounded-full border border-gold-300/25 bg-gold-300/10 px-4 py-2 text-sm font-black uppercase tracking-[0.25em] text-gold-300">Contato enviado</p>
      <h1 class="mt-6 text-4xl font-black tracking-tight sm:text-6xl">Obrigado pelo seu interesse.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">Sua mensagem foi registrada para demonstracao. Quando a integracao com FastAPI ou Flask for ativada, esta pagina podera confirmar o lead salvo no backend.</p>
      <a href="/ibrcanaa/" class="mt-9 rounded-full bg-gold-300 px-7 py-4 font-extrabold text-canaa-950 transition hover:-translate-y-1 hover:bg-white">Voltar para a pagina inicial</a>
    </section>
  </main>
</MainLayout>
