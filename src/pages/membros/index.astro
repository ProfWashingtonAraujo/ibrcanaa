---
import MainLayout from '../../layouts/MainLayout.astro';
import Icon from '../../components/Icon.astro';
import { members } from '../../legacy/mocks/members';
import { events } from '../../legacy/mocks/events';
import { transactions } from '../../legacy/mocks/finance';
import { ministries } from '../../legacy/mocks/ministries';

const member = members[0];
const homeHref = import.meta.env.BASE_URL;
const memberLoginHref = `${import.meta.env.BASE_URL}login/membros/`;

const memberContributions = transactions.filter((transaction) => transaction.description.includes(member.name));
const recommendedMinistries = ministries.filter((ministry) => ministry.status === 'Ativo' || ministry.status === 'Precisa Voluntários').slice(0, 3);
const upcomingEvents = events.slice(0, 3);
const journeySteps = [
  { title: 'Integracao', description: 'Complete seus dados e confirme sua participacao nos proximos cultos.', status: 'Concluido' },
  { title: 'Discipulado', description: 'Acompanhe encontros, materiais e proximas orientacoes pastorais.', status: 'Em andamento' },
  { title: 'Servico', description: 'Conheca ministerios e oportunidades para servir com regularidade.', status: 'Proximo passo' },
];

const formatDate = (date: string) => new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'short',
  hour: '2-digit',
  minute: '2-digit',
}).format(new Date(date));

const formatCurrency = (amount: number) => new Intl.NumberFormat('pt-BR', {
  style: 'currency',
  currency: 'BRL',
}).format(amount);
---

<MainLayout title="Portal do membro | IBR Canaa" description="Portal demonstrativo para membros da Igreja Batista Regular Canaa.">
  <main class="min-h-screen bg-slate-50 text-slate-950">
    <section class="bg-[radial-gradient(circle_at_top_left,rgba(248,217,139,0.18),transparent_30%),linear-gradient(135deg,#07152f,#0f172a)] px-5 py-10 text-white sm:px-6 lg:px-8">
      <div class="mx-auto w-full max-w-7xl">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <a href={homeHref} class="inline-flex items-center gap-2 rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-slate-200 transition hover:border-gold-300/70 hover:bg-white/10">
            <Icon name="arrow" class="h-4 w-4 rotate-180" />
            Voltar para landing page
          </a>
          <a href={memberLoginHref} class="inline-flex items-center gap-2 rounded-full bg-gold-300 px-4 py-2 text-sm font-black text-canaa-950 transition hover:bg-white">Sair do portal</a>
        </div>

        <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_360px] lg:items-end">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.26em] text-gold-300">Portal do membro</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight sm:text-6xl">Bem-vindo, {member.name}</h1>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-300">Acompanhe sua jornada, ministerio, agenda da igreja e informacoes importantes em um painel simples.</p>
          </div>

          <article class="rounded-[1.75rem] border border-white/10 bg-white/10 p-5 shadow-2xl shadow-black/20 backdrop-blur-xl">
            <div class="flex items-center gap-4">
              <img src={member.avatar} alt={`Foto de ${member.name}`} class="h-20 w-20 rounded-3xl border border-white/15 bg-white/10" />
              <div>
                <p class="text-lg font-black">{member.name}</p>
                <p class="text-sm text-slate-300">{member.email}</p>
                <span class="mt-3 inline-flex rounded-full bg-gold-300/15 px-3 py-1 text-xs font-black text-gold-300">{member.status}</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="mx-auto grid w-full max-w-7xl gap-5 px-5 py-8 sm:px-6 md:grid-cols-3 lg:px-8">
      <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-slate-500">Ministerio atual</p>
        <p class="mt-3 text-2xl font-black text-canaa-800">{member.ministry}</p>
      </article>
      <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-slate-500">Frequencia</p>
        <div class="mt-4 flex items-center gap-4">
          <div class="h-3 flex-1 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-emerald-500" style={`width: ${member.frequency}%`}></div>
          </div>
          <p class="text-2xl font-black text-canaa-800">{member.frequency}%</p>
        </div>
      </article>
      <article class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-slate-500">Proximo encontro</p>
        <p class="mt-3 text-2xl font-black text-canaa-800">Domingo, 18h</p>
      </article>
    </section>

    <section class="mx-auto grid w-full max-w-7xl gap-6 px-5 pb-12 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
      <div class="space-y-6">
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-sm font-black uppercase tracking-[0.22em] text-canaa-800">Jornada de fe</p>
              <h2 class="mt-2 text-2xl font-black tracking-tight">Proximos passos do membro</h2>
            </div>
            <button class="rounded-full border border-slate-200 px-4 py-2 text-sm font-bold text-slate-600 transition hover:border-canaa-100 hover:bg-canaa-50 hover:text-canaa-800" type="button">Ver trilha completa</button>
          </div>

          <div class="mt-6 grid gap-4">
            {journeySteps.map((step, index) => (
              <div class="flex gap-4 rounded-3xl border border-slate-100 bg-slate-50 p-4">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-canaa-800 text-sm font-black text-white">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="font-black text-slate-950">{step.title}</h3>
                    <span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-slate-500 ring-1 ring-slate-200">{step.status}</span>
                  </div>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
          <p class="text-sm font-black uppercase tracking-[0.22em] text-canaa-800">Agenda</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight">Proximos eventos</h2>
          <div class="mt-6 divide-y divide-slate-100">
            {upcomingEvents.map((event) => (
              <div class="flex flex-col gap-3 py-4 first:pt-0 last:pb-0 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="font-black text-slate-950">{event.title}</p>
                  <p class="mt-1 text-sm text-slate-500">{event.location} | {event.type}</p>
                </div>
                <span class="rounded-full bg-canaa-50 px-3 py-1.5 text-sm font-black text-canaa-800">{formatDate(event.date)}</span>
              </div>
            ))}
          </div>
        </article>
      </div>

      <aside class="space-y-6">
        <article class="rounded-[1.75rem] border border-canaa-100 bg-canaa-950 p-6 text-white shadow-sm sm:p-7">
          <p class="text-sm font-black uppercase tracking-[0.22em] text-gold-300">Solicitacoes rapidas</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight">Como a igreja pode ajudar?</h2>
          <div class="mt-6 grid gap-3">
            <a href="mailto:contato@ibrcanaa.org" class="rounded-2xl border border-white/10 bg-white/10 p-4 font-bold transition hover:bg-white/15">Pedir aconselhamento pastoral</a>
            <a href="mailto:contato@ibrcanaa.org" class="rounded-2xl border border-white/10 bg-white/10 p-4 font-bold transition hover:bg-white/15">Atualizar meus dados</a>
            <a href="mailto:contato@ibrcanaa.org" class="rounded-2xl border border-white/10 bg-white/10 p-4 font-bold transition hover:bg-white/15">Solicitar entrada em ministerio</a>
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
          <p class="text-sm font-black uppercase tracking-[0.22em] text-canaa-800">Ministerios</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight">Sugestoes para servir</h2>
          <div class="mt-6 space-y-3">
            {recommendedMinistries.map((ministry) => (
              <div class="rounded-2xl border border-slate-100 bg-slate-50 p-4">
                <p class="font-black text-slate-950">{ministry.name}</p>
                <p class="mt-1 text-sm text-slate-500">Lider: {ministry.leader} | {ministry.members} membros</p>
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-7">
          <p class="text-sm font-black uppercase tracking-[0.22em] text-canaa-800">Contribuicoes</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight">Historico recente</h2>
          {memberContributions.length > 0 ? (
            <div class="mt-6 space-y-3">
              {memberContributions.map((transaction) => (
                <div class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50 p-4">
                  <div>
                    <p class="font-black text-slate-950">{transaction.category}</p>
                    <p class="mt-1 text-sm text-slate-500">{new Date(transaction.date).toLocaleDateString('pt-BR')}</p>
                  </div>
                  <p class="font-black text-emerald-600">{formatCurrency(transaction.amount)}</p>
                </div>
              ))}
            </div>
          ) : (
            <p class="mt-5 rounded-2xl bg-slate-50 p-4 text-sm leading-6 text-slate-600">Nenhuma contribuicao vinculada a este usuario demonstrativo.</p>
          )}
        </article>
      </aside>
    </section>
  </main>
</MainLayout>
