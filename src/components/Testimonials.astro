---
import { testimonials } from '../data/landing';
---

<section id="prova-social" class="bg-white py-24 text-slate-950">
  <div class="mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="text-sm font-black uppercase tracking-[0.26em] text-canaa-800">Prova social</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl">Confiança nasce de clareza, acolhimento e consistencia.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">Depoimentos mockados para demonstracao. Substitua por relatos reais em `src/data/landing.ts` quando houver autorizacao dos participantes.</p>
    </div>

    <div class="mt-14 grid gap-5 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <figure class="reveal rounded-[1.75rem] border border-slate-200 bg-slate-50 p-7">
          <div class="flex gap-1 text-gold-500" aria-label="Avaliacao 5 de 5">
            {Array.from({ length: 5 }).map(() => <span aria-hidden="true">★</span>)}
          </div>
          <blockquote class="mt-5 text-lg leading-8 text-slate-700">“{testimonial.quote}”</blockquote>
          <figcaption class="mt-7 border-t border-slate-200 pt-5">
            <p class="font-black text-slate-950">{testimonial.author}</p>
            <p class="mt-1 text-sm font-semibold text-slate-500">{testimonial.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="reveal mt-10 grid gap-4 rounded-[1.75rem] border border-canaa-100 bg-canaa-50 p-6 text-center sm:grid-cols-3">
      <p><strong class="block text-3xl font-black text-canaa-800">4.9/5</strong><span class="text-sm text-slate-600">avaliacao media mockada</span></p>
      <p><strong class="block text-3xl font-black text-canaa-800">24h</strong><span class="text-sm text-slate-600">tempo alvo de resposta</span></p>
      <p><strong class="block text-3xl font-black text-canaa-800">SEO</strong><span class="text-sm text-slate-600">estrutura semantica pronta</span></p>
    </div>
  </div>
</section>
