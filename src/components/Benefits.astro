---
import Icon from './Icon.astro';
import { benefits } from '../data/landing';
---

<section id="beneficios" class="bg-slate-50 py-24 text-slate-950">
  <div class="mx-auto w-full max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="text-sm font-black uppercase tracking-[0.26em] text-canaa-800">Beneficios</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl">Clareza para visitar, participar e crescer em comunidade.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">Uma experiencia pensada para reduzir duvidas, aproximar pessoas e conduzir cada visitante ao proximo passo com seguranca.</p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {benefits.map((benefit) => (
        <article class="reveal group rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-canaa-100 hover:shadow-2xl hover:shadow-canaa-800/10">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-canaa-50 text-canaa-800 transition group-hover:bg-canaa-800 group-hover:text-white">
            <Icon name={benefit.icon} />
          </div>
          <h3 class="mt-7 text-xl font-black">{benefit.title}</h3>
          <p class="mt-3 leading-7 text-slate-600">{benefit.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
