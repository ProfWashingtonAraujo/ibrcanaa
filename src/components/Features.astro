---
import Icon from './Icon.astro';
import { features } from '../data/landing';
---

<section id="diferenciais" class="bg-canaa-950 py-24 text-white">
  <div class="mx-auto grid w-full max-w-7xl gap-12 px-5 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
    <div class="reveal">
      <p class="text-sm font-black uppercase tracking-[0.26em] text-gold-300">Recursos</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl">Construida para conversao, velocidade e evolucao futura.</h2>
      <p class="mt-6 text-lg leading-8 text-slate-300">A estrutura combina UI premium, conteudo escaneavel, SEO basico e pontos preparados para analiticos, Meta Pixel e integracao de leads com FastAPI ou Flask.</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {features.map((feature) => (
        <article class="reveal group rounded-[1.75rem] border border-white/10 bg-white/[0.06] p-7 transition hover:-translate-y-1 hover:bg-white/[0.1]">
          <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-gold-300/15 text-gold-300">
            <Icon name={feature.icon} />
          </div>
          <h3 class="mt-6 text-xl font-black">{feature.title}</h3>
          <p class="mt-3 leading-7 text-slate-300">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
