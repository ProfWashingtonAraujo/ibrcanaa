---
import { faqs } from '../data/landing';
---

<section id="faq" class="bg-slate-50 py-24 text-slate-950">
  <div class="mx-auto grid w-full max-w-7xl gap-10 px-5 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
    <div class="reveal">
      <p class="text-sm font-black uppercase tracking-[0.26em] text-canaa-800">FAQ</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-5xl">Perguntas frequentes antes da visita.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">Respostas diretas diminuem inseguranca e ajudam visitantes a tomar decisao com tranquilidade.</p>
    </div>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="reveal group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="cursor-pointer list-none text-lg font-black marker:hidden">
            <span class="flex items-center justify-between gap-4">
              {faq.question}
              <span class="text-2xl text-canaa-800 transition group-open:rotate-45">+</span>
            </span>
          </summary>
          <p class="mt-4 leading-7 text-slate-600">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
